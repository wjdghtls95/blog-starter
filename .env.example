# ============================================================
# blog-starter environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is in .gitignore.
# ============================================================

# GitHub Actions reads these from repository Secrets.
# Go to: Settings → Secrets and variables → Actions → New repository secret

# ⚠️  OPENAI API KEY — keep this secret, costs money if leaked
OPENAI_API_KEY=sk-...

# ⚠️  Telegram bot token — controls your bot if leaked
TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# Telegram chat ID — your personal chat or group ID
TELEGRAM_CHAT_ID=123456789

# ⚠️  Cloudflare API token — has KV write access
CF_API_TOKEN=...

# Cloudflare account ID — visible in the dashboard URL, not sensitive
CF_ACCOUNT_ID=...

# KV namespace ID — from Workers & Pages → KV
KV_NAMESPACE_ID=...
