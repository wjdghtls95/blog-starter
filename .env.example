# ============================================================
# blog-starter environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is in .gitignore.
# ============================================================

# GitHub Actions reads these from repository Secrets.
# Go to: Settings → Secrets and variables → Actions → New repository secret

# ===== LLM Provider =====
# Choose one provider and set the matching key below.
# Supported values: openai (default) | anthropic | groq | openai-compatible
LLM_PROVIDER=openai

# Model name — leave empty to use each provider's default
# openai default: gpt-4o-mini
# anthropic default: claude-haiku-4-5-20251001
# groq default: llama-3.1-8b-instant
LLM_MODEL=

# Only for openai-compatible (Ollama, Together AI, OpenRouter, etc.)
LLM_BASE_URL=

# ===== LLM API Keys =====
# Set only the key for the provider you're using.

# ⚠️  OpenAI — costs money if leaked
OPENAI_API_KEY=sk-...

# ⚠️  Anthropic (Claude) — costs money if leaked
ANTHROPIC_API_KEY=sk-ant-...

# Groq — free tier available at console.groq.com
GROQ_API_KEY=gsk_...

# Generic key for openai-compatible providers
LLM_API_KEY=

# ===== Telegram =====
# ⚠️  Bot token — controls your bot if leaked
TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# Your personal chat ID — get it from @userinfobot
TELEGRAM_CHAT_ID=123456789

# ===== Cloudflare =====
# ⚠️  API token — has KV write access
CF_API_TOKEN=...

# Account ID — visible in the dashboard URL
CF_ACCOUNT_ID=...

# KV namespace ID — from Workers & Pages → KV
KV_NAMESPACE_ID=...
